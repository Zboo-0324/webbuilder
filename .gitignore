# Publish only the WebBuilder Skill package and its bilingual README files.
/*
!/.gitignore
!/README.md
!/README_EN.md
!/webbuilder/
!/webbuilder/**

# Keep local Skill runtime and development artifacts out of the public package.
__pycache__/
*.py[cod]
.worktrees/
webbuilder/.transitions/
webbuilder/.migration-backup-*/
